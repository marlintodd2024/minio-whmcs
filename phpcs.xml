<?xml version="1.0"?>
<ruleset name="ImpulseMinio">
    <description>Code style rules for ImpulseMinio WHMCS module</description>

    <!-- Scan these paths -->
    <file>modules/servers/impulseminio</file>
    <file>includes/hooks</file>

    <!-- Exclude templates -->
    <exclude-pattern>*/templates/*</exclude-pattern>

    <!-- Base standard -->
    <rule ref="PSR12">
        <!-- WHMCS modules use snake_case function names by convention -->
        <exclude name="PSR1.Methods.CamelCapsMethodName"/>
        <!-- Module files aren't classes -->
        <exclude name="PSR1.Files.SideEffects"/>
        <exclude name="PSR1.Classes.ClassDeclaration"/>
    </rule>

    <!-- Allow long lines for HTML output in renderClientArea (heredocs, etc.) -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="200"/>
            <property name="absoluteLineLimit" value="0"/>
        </properties>
    </rule>
</ruleset>
