{
    "name": "impulsehosting/minio-whmcs",
    "description": "S3-compatible object storage provisioning module for WHMCS using MinIO",
    "type": "whmcs-server-module",
    "license": "proprietary",
    "authors": [
        {
            "name": "Impulse Hosting",
            "email": "support@impulsehosting.com"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "files": [
            "modules/servers/impulseminio/lib/MinioClient.php"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    }
}
